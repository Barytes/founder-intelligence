OPENAI_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com/v1
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
# Named custom providers use <NAME>_LLM_API_KEY.
MOONSHOT_AI_LLM_API_KEY=
# Source discovery sends only minimized query strings to this provider.
BRAVE_SEARCH_API_KEY=

# L4 is the default path. Set the compatibility fallback to 1 for one release.
FI_L4_LEGACY_FALLBACK=0
FI_L4_PROFILE_ENABLED=1
FI_L4_SOURCE_CATALOG_ENABLED=1
FI_L4_SOURCE_DISCOVERY_ENABLED=1
FI_L4_AGENT_RANKING_ENABLED=1
FI_L4_INBOX_ENABLED=1
FI_L4_WORKFLOW_ENABLED=1
